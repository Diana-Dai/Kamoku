{% doc %}
  @prompt
    Create a luxury minimalist Shopify product feature section with a refined editorial aesthetic inspired by premium skincare and fashion brands. Use a soft warm light-gray background with a clean two-column layout.
    
    Left side:
    
    Large lifestyle product image inside a square frame
    Minimal open white box packaging centered in the image
    Warm beige interior flaps visible inside the box
    Soft studio lighting with subtle shadows
    Premium muted editorial photography style
    Top-right floating olive-green label with small cube icon and uppercase text:
    “COMPLETE BUNDLE”
    Bottom-left black promotional tag:
    “Save $27”
    Clean negative space and elevated luxury composition
    
    Right side:
    
    Elegant oversized serif headline:
    “The Recovery Bundle”
    High-fashion typography similar to luxury beauty campaigns
    Supporting paragraph beneath:
    “Complete 14-day protection. All three stages in one intentional system.”
    Large pricing display:
    Current price: “$98”
    Original price “$125” in smaller crossed-out styling
    Thin divider line
    Minimal bullet list with generous spacing:
    01 HYDRO GEL
    02 RECOVERY MIST
    03 DAILY CARE BALM
    Another subtle divider line
    Large full-width black CTA button with white uppercase text:
    “SECURE YOUR SYSTEM”
    Small centered caption underneath:
    “Recommended for large pieces & sleeves”
    
    Design style:
    luxury skincare Shopify section, minimalist editorial branding, premium tattoo aftercare aesthetic, monochromatic neutral palette, serif + sans-serif typography pairing, soft lighting, modern fashion campaign layout, high-end ecommerce design, clean spacing, sophisticated product storytelling, premium DTC brand aesthetic.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-luxury-product-feature-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-luxury-product-feature__container-{{ ai_gen_id }} {
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.column_gap }}px;
    align-items: center;
  }

  .ai-luxury-product-feature__image-column-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-luxury-product-feature__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-luxury-product-feature__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-luxury-product-feature__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-luxury-product-feature__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-luxury-product-feature__badge-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.badge_position_top }}px;
    right: {{ block.settings.badge_position_right }}px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 10px 16px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .ai-luxury-product-feature__badge-icon-{{ ai_gen_id }} {
    width: 14px;
    height: 14px;
    background-color: currentColor;
    border-radius: 2px;
  }

  .ai-luxury-product-feature__promo-tag-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.promo_position_bottom }}px;
    left: {{ block.settings.promo_position_left }}px;
    background-color: {{ block.settings.promo_background }};
    color: {{ block.settings.promo_text_color }};
    padding: 8px 16px;
    border-radius: {{ block.settings.promo_border_radius }}px;
    font-size: {{ block.settings.promo_font_size }}px;
    font-weight: 600;
  }

  .ai-luxury-product-feature__content-column-{{ ai_gen_id }} {
    padding: 0 {{ block.settings.content_padding }}px;
  }

  .ai-luxury-product-feature__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_margin }}px 0;
    line-height: 1.1;
    letter-spacing: -0.5px;
  }

  .ai-luxury-product-feature__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0 0 {{ block.settings.description_margin }}px 0;
  }

  .ai-luxury-product-feature__price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: {{ block.settings.price_margin }}px;
  }

  .ai-luxury-product-feature__price-current-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: 600;
    color: {{ block.settings.price_color }};
  }

  .ai-luxury-product-feature__price-original-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_compare_size }}px;
    color: {{ block.settings.price_compare_color }};
    text-decoration: line-through;
    opacity: 0.6;
  }

  .ai-luxury-product-feature__divider-{{ ai_gen_id }} {
    width: 100%;
    height: 1px;
    background-color: {{ block.settings.divider_color }};
    margin: {{ block.settings.divider_margin }}px 0;
  }

  .ai-luxury-product-feature__list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0 0 {{ block.settings.list_margin }}px 0;
  }

  .ai-luxury-product-feature__list-item-{{ ai_gen_id }} {
    font-size: {{ block.settings.list_font_size }}px;
    color: {{ block.settings.list_color }};
    margin-bottom: {{ block.settings.list_item_spacing }}px;
    letter-spacing: 1px;
    font-weight: 400;
  }

  .ai-luxury-product-feature__button-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    padding: {{ block.settings.button_padding }}px 32px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    text-align: center;
    transition: background-color 0.3s ease;
  }

  .ai-luxury-product-feature__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-luxury-product-feature__caption-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.caption_font_size }}px;
    color: {{ block.settings.caption_color }};
    margin-top: {{ block.settings.caption_margin }}px;
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-luxury-product-feature__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-luxury-product-feature__content-column-{{ ai_gen_id }} {
      padding: 0;
    }

    .ai-luxury-product-feature__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-luxury-product-feature__badge-{{ ai_gen_id }} {
      top: 16px;
      right: 16px;
      font-size: 10px;
      padding: 8px 12px;
    }

    .ai-luxury-product-feature__promo-tag-{{ ai_gen_id }} {
      bottom: 16px;
      left: 16px;
      font-size: 12px;
    }
  }
{% endstyle %}

<div class="ai-luxury-product-feature-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-luxury-product-feature__container-{{ ai_gen_id }}">
    <div class="ai-luxury-product-feature__image-column-{{ ai_gen_id }}">
      <div class="ai-luxury-product-feature__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.product_image %}
          <img
            src="{{ block.settings.product_image | image_url: width: 1000 }}"
            alt="{{ block.settings.product_image.alt | escape }}"
            class="ai-luxury-product-feature__image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.product_image.width }}"
            height="{{ block.settings.product_image.height }}"
          >
        {% else %}
          <div class="ai-luxury-product-feature__image-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if block.settings.show_badge and block.settings.badge_text != blank %}
          <div class="ai-luxury-product-feature__badge-{{ ai_gen_id }}">
            {% if block.settings.show_badge_icon %}
              <span class="ai-luxury-product-feature__badge-icon-{{ ai_gen_id }}"></span>
            {% endif %}
            {{ block.settings.badge_text }}
          </div>
        {% endif %}

        {% if block.settings.show_promo_tag and block.settings.promo_text != blank %}
          <div class="ai-luxury-product-feature__promo-tag-{{ ai_gen_id }}">
            {{ block.settings.promo_text }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-luxury-product-feature__content-column-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-luxury-product-feature__heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-luxury-product-feature__description-{{ ai_gen_id }}">
          {{ block.settings.description }}
        </div>
      {% endif %}

      {% if block.settings.show_price %}
        <div class="ai-luxury-product-feature__price-wrapper-{{ ai_gen_id }}">
          {% if block.settings.current_price != blank %}
            <span class="ai-luxury-product-feature__price-current-{{ ai_gen_id }}">
              {{ block.settings.current_price }}
            </span>
          {% endif %}
          {% if block.settings.original_price != blank %}
            <span class="ai-luxury-product-feature__price-original-{{ ai_gen_id }}">
              {{ block.settings.original_price }}
            </span>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.show_divider_1 %}
        <div class="ai-luxury-product-feature__divider-{{ ai_gen_id }}"></div>
      {% endif %}

      {% if block.settings.show_list %}
        <ul class="ai-luxury-product-feature__list-{{ ai_gen_id }}">
          {% if block.settings.list_item_1 != blank %}
            <li class="ai-luxury-product-feature__list-item-{{ ai_gen_id }}">
              {{ block.settings.list_item_1 }}
            </li>
          {% endif %}
          {% if block.settings.list_item_2 != blank %}
            <li class="ai-luxury-product-feature__list-item-{{ ai_gen_id }}">
              {{ block.settings.list_item_2 }}
            </li>
          {% endif %}
          {% if block.settings.list_item_3 != blank %}
            <li class="ai-luxury-product-feature__list-item-{{ ai_gen_id }}">
              {{ block.settings.list_item_3 }}
            </li>
          {% endif %}
        </ul>
      {% endif %}

      {% if block.settings.show_divider_2 %}
        <div class="ai-luxury-product-feature__divider-{{ ai_gen_id }}"></div>
      {% endif %}

      {% if block.settings.button_text != blank %}
        <a
          href="{{ block.settings.button_link }}"
          class="ai-luxury-product-feature__button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
        </a>
      {% endif %}

      {% if block.settings.caption != blank %}
        <div class="ai-luxury-product-feature__caption-{{ ai_gen_id }}">
          {{ block.settings.caption }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

